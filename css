body {
    font-family: Arial;
    background: #f4f8fb;
    padding: 20px;
}

input, select, button {
    padding: 8px;
    margin: 5px;
}

button {
    background: #3498db;
    color: white;
    border: none;
}

table {
    width: 100%;
    background: white;
    border-collapse: collapse;
}

th, td {
    border: 1px solid #ddd;
    padding: 10px;
}
